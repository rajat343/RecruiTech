INTERVIEW_SERVICE_PORT=5001
NODE_ENV=development

# MongoDB (same database as backend)
MONGODB_URL=mongodb://localhost:27017/recruitech

# JWT (must match backend JWT_SECRET)
JWT_SECRET=your_jwt_secret_here

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o

# Kafka — host-run service: localhost:9092. Docker-only clients on recruitech-kafka network: kafka:9094
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# gRPC (machine-to-machine control plane; REST + WebSocket unchanged)
GRPC_ENABLED=true
GRPC_PORT=50051
# If set, all gRPC requests must send the same value in internal_secret
# GRPC_INTERNAL_SECRET=change-me

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173
